# Horizontal (16:9) Twitch instance — copy to stream/.env.twitch and fill in.
# Captures the existing TV page (flight-deck noir) with route info hidden.
#
# Stream key: Twitch dashboard -> Settings -> Stream. Twitch RTMPS ingest:
RTMP_URL=rtmps://live.twitch.tv:443/app
STREAM_KEY=live_your-twitch-key-here

PAGE_URL=http://localhost:3000/tv.html?route=0
RES=1280x720
VBITRATE=3000k
DISPLAY_NUM=:23        # must differ per running instance (:22 = tiktok)

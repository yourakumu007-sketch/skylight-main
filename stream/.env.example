# Instance env files: start-stream.sh <name> reads stream/.env.<name>
# (bare ./start-stream.sh reads .env). One file per destination, e.g.:
#   .env.tiktok  — vertical 9:16 via Restream  (this template)
#   .env.twitch  — horizontal 16:9 direct      (see .env.twitch.example)
# All real .env files are gitignored — stream keys are credentials.
#
# Prefer the RTMPS url your provider shows (TLS — same pipeline, key not sent
# in plaintext). Works for Restream, TikTok direct, or any RTMP(S) ingest.
RTMP_URL=rtmps://live.restream.io:1937/live
STREAM_KEY=your-stream-key-here

DISPLAY_NUM=:22       # must differ per running instance (:23 = twitch)

# Optional overrides:
#PAGE_URL=http://localhost:3000/stream.html
#PAGE_URL=http://localhost:3000/stream.html?route=1   # show origin/destination
#RES=1080x1920        # default 720x1280; 1080 needs a beefier encoder box
#FPS=30
#VBITRATE=2500k       # use 4500k with RES=1080x1920
#ENCODER=libx264      # or h264_v4l2m2m (Pi 4 hardware encoder)
